{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neuroweave.local/schemas/reproducibility-graph.schema.json",
  "title": "NeuroWeave reproducibility graph v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "graph_kind",
    "created_at_utc",
    "dataset_id",
    "root_node_id",
    "terminal_node_id",
    "nodes",
    "edges",
    "diagnostics"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "graph_kind": {
      "const": "reproducibility_graph"
    },
    "created_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "dataset_id": {
      "type": "string",
      "minLength": 1
    },
    "root_node_id": {
      "type": "string",
      "minLength": 1
    },
    "terminal_node_id": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "diagnostics": {
      "$ref": "#/$defs/diagnostics"
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "node_id",
        "kind",
        "label",
        "dataset_id",
        "diagnostics"
      ],
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": [
            "dataset",
            "preprocessing_run",
            "epoch_run",
            "erp_run",
            "comparison"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "dataset_id": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string"
        },
        "run_kind": {
          "enum": ["preprocessing", "epoch", "erp"]
        },
        "status": {
          "type": "string"
        },
        "config_snapshot": {
          "type": "object"
        },
        "config_digest_sha256": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "artifact_manifest": {
          "type": ["object", "null"]
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact"
          }
        },
        "worker": {
          "type": ["object", "null"]
        },
        "provenance": {
          "type": ["object", "null"]
        },
        "phase_d": {
          "type": "object"
        },
        "batch": {
          "type": ["object", "null"]
        },
        "comparison_summary_path": {
          "type": "string"
        },
        "metric": {
          "type": "string"
        },
        "condition_pair": {
          "type": "object"
        },
        "statistics": {
          "type": "object"
        },
        "diagnostics": {
          "$ref": "#/$defs/diagnostics"
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["edge_id", "source", "target", "relation"],
      "properties": {
        "edge_id": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "relation": {
          "enum": ["contains", "produced", "derived_from", "compares"]
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logical_name", "artifact_type", "path", "exists"],
      "properties": {
        "logical_name": {
          "type": "string",
          "minLength": 1
        },
        "artifact_type": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "checksum_sha256": {
          "type": ["string", "null"]
        },
        "size_bytes": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "exists": {
          "type": "boolean"
        }
      }
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["warnings"],
      "properties": {
        "warnings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "code",
              "severity",
              "source",
              "impact",
              "suggested_action"
            ],
            "properties": {
              "code": {
                "type": "string",
                "minLength": 1
              },
              "severity": {
                "enum": ["warning", "error"]
              },
              "source": {
                "enum": [
                  "bids",
                  "event_mapping",
                  "validation",
                  "worker",
                  "artifact",
                  "export_bundle",
                  "batch"
                ]
              },
              "impact": {
                "type": "string",
                "minLength": 1
              },
              "suggested_action": {
                "type": ["string", "null"]
              }
            }
          }
        }
      }
    }
  }
}
