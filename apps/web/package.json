{
  "name": "@neuroweave/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "e2e:phase2": "playwright test e2e/phase2-smoke.spec.ts",
    "e2e:phase-c": "playwright test e2e/phase-c-batch-smoke.spec.ts",
    "e2e:phase3:epoch": "playwright test e2e/phase3-epoch-smoke.spec.ts",
    "e2e:phase3:erp": "playwright test e2e/phase3-erp-smoke.spec.ts",
    "e2e:phase3": "playwright test e2e/phase3-epoch-smoke.spec.ts e2e/phase3-erp-smoke.spec.ts",
    "e2e:visual-seed": "playwright test e2e/visual-regression-seed.spec.ts",
    "e2e:all": "npm run e2e:phase2 && npm run e2e:phase-c && npm run e2e:phase3:epoch && npm run e2e:phase3:erp"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.5.0",
    "vite": "^7.0.0"
  }
}
